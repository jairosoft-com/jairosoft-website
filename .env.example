# Server-side only (NOT exposed to the frontend)
# These are read by the Next.js Route Handlers in src/app/api/*
GOHIGHLEVEL_API_KEY=your_api_key_here
GOHIGHLEVEL_LOCATION_ID=your_location_id_here

# Contact Form Pipeline
GOHIGHLEVEL_PIPELINE_ID=your_pipeline_id_here
GOHIGHLEVEL_STAGE_ID=your_stage_id_here

# Internship Pipeline
GOHIGHLEVEL_INTERNSHIP_PIPELINE_ID=your_internship_pipeline_id_here
GOHIGHLEVEL_INTERNSHIP_STAGE_ID=your_internship_stage_id_here

# Employment Verification Pipeline
GOHIGHLEVEL_EMPLOYMENT_VERIFICATION_PIPELINE_ID=your_employment_verification_pipeline_id_here
GOHIGHLEVEL_EMPLOYMENT_VERIFICATION_STAGE_ID=your_employment_verification_stage_id_here
